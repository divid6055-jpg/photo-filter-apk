<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/brand_primary_dark"
                android:endColor="@color/brand_secondary_dark"
                android:angle="45" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/brand_text_disabled" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/gradient_sunset_start"
                android:endColor="@color/gradient_rose_end"
                android:angle="45" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</selector>
