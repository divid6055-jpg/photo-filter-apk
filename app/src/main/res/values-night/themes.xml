<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.PhotoFilterPro" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary_light</item>
        <item name="colorOnPrimary">@color/brand_text_primary</item>
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="android:colorBackground">@color/brand_dark_background</item>
        <item name="colorSurface">@color/brand_dark_surface</item>
        <item name="colorSurfaceVariant">@color/brand_dark_surface_variant</item>
        <item name="colorOnSurface">@color/brand_dark_text_primary</item>

        <item name="android:textColorPrimary">@color/brand_dark_text_primary</item>
        <item name="android:textColorSecondary">@color/brand_dark_text_secondary</item>
        <item name="android:textColor">@color/brand_dark_text_primary</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <item name="android:windowAnimationStyle">@style/Animation.PhotoFilterPro</item>
        <item name="android:windowActivityTransitions">true</item>

        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.App.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.App.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.App.Large</item>

        <item name="materialAlertDialogTheme">@style/ThemeOverlay.App.MaterialAlertDialog</item>
        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.App.BottomSheetDialog</item>
    </style>
</resources>
