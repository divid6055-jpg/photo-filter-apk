<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.PhotoFilterPro" parent="Theme.PhotoFilterPro.Light">
        <item name="android:colorBackground">@color/brand_dark_background</item>
        <item name="android:textColor">@color/brand_dark_text</item>
        <item name="android:textColorSecondary">@color/brand_dark_text_secondary</item>
        <item name="android:statusBarColor">@color/brand_dark_background</item>
        <item name="android:navigationBarColor">@color/brand_dark_background</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.PhotoFilterPro.Light" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/brand_on_primary</item>
        <item name="colorSecondary">@color/brand_secondary</item>
    </style>
</resources>
