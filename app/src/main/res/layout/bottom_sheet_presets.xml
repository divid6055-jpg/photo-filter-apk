<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:padding="16dp">

    <!-- مقبض السحب -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_drag_handle" />

    <!-- العنوان -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/presets_title"
        android:textAppearance="@style/TextAppearance.App.Headline"
        android:textSize="20sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="اختر إعداداً جاهزاً لتطبيقه بنقرة واحدة"
        android:textAppearance="@style/TextAppearance.App.Body"
        android:textSize="13sp" />

    <!-- قائمة الـ Presets -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_presets"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:minHeight="200dp"
        android:nestedScrollingEnabled="false" />

</LinearLayout>
